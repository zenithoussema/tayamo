generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id            Int        @id @default(autoincrement())
  nameAr        String
  nameFr        String
  slug          String     @unique
  descriptionAr String
  descriptionFr String
  ageRangeMin   Int        @default(4)
  ageRangeMax   Int        @default(99)
  iconName      String?
  coverImageUrl String?
  createdAt     DateTime   @default(now())
  isActive      Boolean    @default(true)
  bookings      Booking[]
  schedules     Schedule[]
}

model Coach {
  id              Int        @id @default(autoincrement())
  name            String
  specialty       String
  imageUrl        String?
  bio             String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  assignedClients Client[]
  schedules       Schedule[]
}

model Schedule {
  id         Int              @id @default(autoincrement())
  activityId Int
  dayOfWeek  DayOfWeek
  startTime  String
  endTime    String
  coachName  String
  createdAt  DateTime         @default(now())
  coachId    Int?
  category   ScheduleCategory @default(ADULTS)
  isActive   Boolean          @default(true)
  season     ScheduleSeason   @default(SUMMER)
  bookings   Booking[]
  activity   Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  coach      Coach?           @relation(fields: [coachId], references: [id])
}

model Booking {
  id             Int           @id @default(autoincrement())
  parentName     String
  parentPhone    String
  childName      String
  childBirthDate DateTime?
  activityId     Int
  scheduleId     Int?
  isTrialSession Boolean       @default(true)
  status         BookingStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  activity       Activity      @relation(fields: [activityId], references: [id])
  schedule       Schedule?     @relation(fields: [scheduleId], references: [id])
}

model Testimonial {
  id         Int      @id @default(autoincrement())
  authorName String
  content    String
  rating     Int
  approved   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model ContactMessage {
  id               Int      @id @default(autoincrement())
  name             String
  phone            String
  email            String?
  message          String
  activityInterest String?
  handled          Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model SubscriptionPlan {
  id           Int      @id @default(autoincrement())
  name         String
  price        Float
  durationDays Int
  features     String   @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  clients      Client[]
}

model Client {
  id                       Int               @id @default(autoincrement())
  fullName                 String
  phone                    String
  activity                 String
  subscriptionStartDate    DateTime          @default(now())
  subscriptionDurationDays Int               @default(30)
  pricePaid                Float
  notes                    String?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  assignedCoachId          Int?
  category                 MemberCategory    @default(FITNESS)
  dateOfBirth              DateTime?
  email                    String?
  isActive                 Boolean           @default(true)
  planId                   Int?
  profileImageUrl          String?
  attendances              Attendance[]
  assignedCoach            Coach?            @relation(fields: [assignedCoachId], references: [id])
  plan                     SubscriptionPlan? @relation(fields: [planId], references: [id])
  feedbacks                Feedback[]
  payments                 Payment[]
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  email        String     @unique
  passwordHash String
  fullName     String
  role         UserRole   @default(RECEPTION)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Payment {
  id          Int           @id @default(autoincrement())
  clientId    Int
  amount      Float
  method      PaymentMethod @default(CASH)
  reference   String?
  description String?
  date        DateTime      @default(now())
  createdAt   DateTime      @default(now())
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        Int           @id @default(autoincrement())
  clientId  Int
  checkIn   DateTime      @default(now())
  checkOut  DateTime?
  method    CheckInMethod @default(MANUAL)
  notes     String?
  createdAt DateTime      @default(now())
  client    Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType @default(INFO)
  title     String
  message   String
  entity    String?
  entityId  Int?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String
  entityId  Int?
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Feedback {
  id        Int            @id @default(autoincrement())
  clientId  Int
  type      FeedbackType   @default(REVIEW)
  subject   String
  message   String
  status    FeedbackStatus @default(PENDING)
  reply     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  client    Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model News {
  id          Int          @id @default(autoincrement())
  title       String
  titleAr     String?
  content     String
  contentAr   String?
  imageUrl    String?
  videoUrl    String?
  category    NewsCategory @default(NEWS)
  isPublished Boolean      @default(false)
  isFeatured  Boolean      @default(false)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ShopCategory {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String        @unique
  description String?
  icon        String?
  imageUrl    String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  products    ShopProduct[]
}

model ShopProduct {
  id             Int             @id @default(autoincrement())
  name           String
  slug           String          @unique
  description    String
  shortDesc      String?
  price          Float
  compareAtPrice Float?
  images         String          @default("[]")
  categoryId     Int
  brand          String?
  sku            String?
  stock          Int             @default(0)
  rating         Float           @default(0)
  reviewCount    Int             @default(0)
  isFeatured     Boolean         @default(false)
  isNew          Boolean         @default(false)
  isBestSeller   Boolean         @default(false)
  isActive       Boolean         @default(true)
  tags           String          @default("[]")
  specifications String          @default("{}")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  colors         String          @default("[]")
  productType    String?
  sizes          String          @default("[]")
  weight         Float?
  orderItems     ShopOrderItem[]
  category       ShopCategory    @relation(fields: [categoryId], references: [id])
  reviews        ShopReview[]
}

model ShopOrder {
  id            Int             @id @default(autoincrement())
  customerName  String
  customerEmail String?
  customerPhone String
  address       String
  city          String
  notes         String?
  total         Float
  status        ShopOrderStatus @default(NOUVEAU)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         ShopOrderItem[]
}

model ShopOrderItem {
  id        Int         @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     ShopOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   ShopProduct @relation(fields: [productId], references: [id])
}

model ShopReview {
  id         Int         @id @default(autoincrement())
  productId  Int
  authorName String
  rating     Int
  content    String
  approved   Boolean     @default(false)
  createdAt  DateTime    @default(now())
  product    ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum UserRole {
  OWNER
  MANAGER
  TRAINER
  RECEPTION
}

enum MemberCategory {
  BODYBUILDING
  BOXING
  FITNESS
  CALISTHENICS
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_PAYMENT
  OTHER
}

enum CheckInMethod {
  MANUAL
  QR_CODE
  PHONE_SEARCH
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  EXPIRATION
  PAYMENT
}

enum FeedbackType {
  REVIEW
  SUGGESTION
  COMPLAINT
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  SOLVED
  DISMISSED
}

enum ScheduleCategory {
  KIDS
  ADULTS
  WOMEN
}

enum ScheduleSeason {
  SUMMER
  WINTER
}

enum ShopOrderStatus {
  NOUVEAU
  EN_COURS
  CONFIRME
  LIVRE
  ANNULE
}

enum NewsCategory {
  NEWS
  EVENT
  ANNOUNCEMENT
  ADMIN_POST
}
